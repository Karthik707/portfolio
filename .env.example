# ----------------------------------------------------------------------------
# Environment variables for the portfolio site. Copy this file to `.env` and
# fill in real values. All client-exposed variables MUST be prefixed with VITE_.
# ----------------------------------------------------------------------------

# Formspree form endpoint ID. Create a free form at https://formspree.io
# and paste the ID portion of the endpoint here (e.g. "xpzgkqYZ").
# The contact form posts to https://formspree.io/f/<id>.
VITE_FORMSPREE_ID=your_formspree_id

# Public base path. Use "/" for Vercel/Netlify and a custom domain.
# For GitHub Pages project sites use "/<repo-name>/".
VITE_BASE=/

# Canonical site URL used for SEO/Open Graph tags.
VITE_SITE_URL=https://karthikkulal.dev
